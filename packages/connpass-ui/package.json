{
  "name": "@kajidog/connpass-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Connpass event browser UI for MCP Apps Extension",
  "main": "./dist/mcp-app.html",
  "exports": {
    ".": "./dist/mcp-app.html"
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "build:dev": "NODE_ENV=development vite build",
    "dev": "vite",
    "repro:format-event": "tsc scripts/repro-format-event.ts --outDir .tmp-scripts --module nodenext --target ES2020 --moduleResolution nodenext --esModuleInterop && node .tmp-scripts/repro-format-event.js"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
