# ============================================
# Connpass MCP Server 設定
# ============================================

# Connpass API Key (required for production)
CONNPASS_API_KEY=your-api-key-here

# Default user ID for search_schedule (optional)
CONNPASS_DEFAULT_USER_ID=

# Rate limiting
CONNPASS_RATE_LIMIT_ENABLED=true
CONNPASS_RATE_LIMIT_DELAY_MS=1000

# ============================================
# HTTP モード設定
# ============================================

# HTTP mode (set true for Docker / remote deployment)
MCP_HTTP_MODE=false
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=0.0.0.0
# MCP_API_KEY=           # Optional: require API key for HTTP mode
# MCP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1
