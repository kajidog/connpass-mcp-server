# Connpass API Key (required for production)
CONNPASS_API_KEY=your-api-key-here

# Default user ID for search_schedule (optional)
CONNPASS_DEFAULT_USER_ID=

# Include presentations by default (optional, true/false)
CONNPASS_INCLUDE_PRESENTATIONS_DEFAULT=false

# Presentation cache settings
CONNPASS_PRESENTATION_CACHE_ENABLED=true
CONNPASS_PRESENTATION_CACHE_TTL_MS=3600000
CONNPASS_PRESENTATION_CACHE_PATH=./data/presentation-cache.json

# Enable Apps SDK output (optional, true/false)
CONNPASS_ENABLE_APPS_SDK_OUTPUT=false

# OAuth Settings (optional)
# Set MCP_OAUTH_ENABLED=true to enable JWT verification
MCP_OAUTH_ENABLED=false
MCP_SERVER_URL=http://localhost:3000
MCP_AUTH_SERVER_URL=http://localhost:3001
MCP_JWKS_URI=http://localhost:3001/.well-known/jwks.json
# Optional: Validate issuer
# MCP_ISSUER=http://localhost:3001
MCP_OAUTH_SCOPES=mcp:tools,mcp:resources
MCP_RESOURCE_NAME="Connpass MCP Server"
