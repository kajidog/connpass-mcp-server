{
  "name": "@kajidog/connpass-mcp-server",
  "version": "0.4.0",
  "type": "module",
  "description": "MCP server for Connpass API integration with MCP Apps Extension support",
  "main": "./dist/index.js",
  "bin": {
    "connpass-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "NODE_ENV=development tsx src/index.ts",
    "dev:http": "NODE_ENV=development MCP_HTTP_MODE=true tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@kajidog/connpass-api-client": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kajidog/mcp-core": "workspace:*",
    "@kajidog/connpass-ui": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["mcp", "mcp-server", "connpass", "mcp-apps"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kajidog/connpass-mcp-server.git",
    "directory": "apps/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/kajidog/connpass-mcp-server/issues"
  },
  "homepage": "https://github.com/kajidog/connpass-mcp-server#readme",
  "engines": {
    "node": ">=18"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js"
  }
}
