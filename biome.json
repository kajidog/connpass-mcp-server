{
  "$schema": "https://biomejs.dev/schemas/1.5.0/schema.json",
  "files": {
    "include": [
      "biome.json",
      "package.json",
      ".github/**/*.yml",
      "apps/mcp-server/package.json",
      "apps/mcp-server/src/**/*.ts",
      "packages/api-client/**/*.ts",
      "packages/mcp-core/src/**/*.ts",
      "packages/connpass-ui/src/**/*.tsx",
      "packages/connpass-ui/src/**/*.ts"
    ],
    "ignore": [
      "**/dist/**",
      "**/node_modules/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "recommended": true
      },
      "style": {
        "recommended": false
      },
      "suspicious": {
        "recommended": false
      }
    }
  }
}
